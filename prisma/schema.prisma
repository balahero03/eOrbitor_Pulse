generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(cuid())
  email              String            @unique
  passwordHash       String
  firstName          String
  lastName           String
  role               UserRole          @default(SALES_EXEC)
  department         String?
  assignedTerritory  String?
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  managerId          String?
  activityLogs       ActivityLog[]
  announcements      Announcement[]
  approvalsApproved  ApprovalRequest[] @relation("ApprovalApprovedBy")
  approvalsRequested ApprovalRequest[] @relation("ApprovalRequestedBy")
  dailyActivities    DailyActivity[]
  deals              Deal[]
  followUps          FollowUp[]
  leads              Lead[]            @relation("LeadAssignedTo")
  broughtLeads       Lead[]            @relation("LeadBroughtBy")
  notifications      Notification[]
  quotations         Quotation[]
  assignedTasks      Task[]            @relation("assignedTo")
  tasks              Task[]
  assignedTickets    Ticket[]          @relation("assignedTo")
  createdTickets     Ticket[]          @relation("createdBy")
  timeLogs           TimeLog[]
  manager            User?             @relation("UserManager", fields: [managerId], references: [id])
  subordinates       User[]            @relation("UserManager")

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model Lead {
  id                 String            @id @default(cuid())
  name               String
  email              String
  phone              String?
  company            String
  source             LeadSource
  status             LeadStatus        @default(NEW)
  leadScore          Int               @default(0)
  qualificationNotes String?
  assignedToId       String
  nextFollowUp       DateTime?
  linkedCustomerId   String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  broughtById        String?
  followUpDate       DateTime?
  poReceivedDate     DateTime?
  quoteNo            String?
  quoteValue         Decimal?
  remarks            String?
  rfqDate            DateTime?
  activityLogs       ActivityLog[]
  approvalRequests   ApprovalRequest[]
  deals              Deal[]
  followUps          FollowUp[]
  assignedTo         User              @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  broughtBy          User?             @relation("LeadBroughtBy", fields: [broughtById], references: [id])
  linkedCustomer     Customer?         @relation(fields: [linkedCustomerId], references: [id])

  @@index([status])
  @@index([assignedToId])
  @@index([createdAt])
}

model Customer {
  id               String           @id @default(cuid())
  companyName      String
  gstNumber        String           @unique
  industry         String?
  website          String?
  annualRevenue    Decimal?
  yearEstablished  Int?
  billingAddress   Json?
  shippingAddress  Json?
  customerCategory CustomerCategory @default(PROSPECT)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?
  activityLogs     ActivityLog[]
  contacts         Contact[]
  deals            Deal[]
  leads            Lead[]
  orders           Order[]
  quotations       Quotation[]
  tickets          Ticket[]

  @@index([gstNumber])
  @@index([createdAt])
}

model Contact {
  id          String   @id @default(cuid())
  customerId  String
  name        String
  email       String
  phone       String?
  designation String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Deal {
  id                String        @id @default(cuid())
  customerId        String
  leadId            String?
  dealName          String
  dealValue         Decimal
  stage             DealStage     @default(SUSPECT)
  winProbability    Int           @default(0)
  expectedCloseDate DateTime?
  assignedToId      String
  nextAction        String?
  lostReason        String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  closedAt          DateTime?
  activityLogs      ActivityLog[]
  assignedTo        User          @relation(fields: [assignedToId], references: [id])
  customer          Customer      @relation(fields: [customerId], references: [id])
  lead              Lead?         @relation(fields: [leadId], references: [id])
  followUps         FollowUp[]
  orders            Order[]
  quotations        Quotation[]
  tasks             Task[]
  tickets           Ticket[]

  @@index([stage])
  @@index([customerId])
  @@index([assignedToId])
}

model FollowUp {
  id              String       @id @default(cuid())
  dealId          String
  leadId          String?
  type            FollowUpType
  scheduledDate   DateTime
  actualDate      DateTime?
  durationMinutes Int?
  notes           String?
  outcome         String?
  nextAction      String?
  createdById     String
  reminderSentAt  DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       User         @relation(fields: [createdById], references: [id])
  deal            Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lead            Lead?        @relation(fields: [leadId], references: [id])
  tasks           Task[]

  @@index([dealId])
  @@index([createdById])
  @@index([scheduledDate])
}

model Task {
  id                String       @id @default(cuid())
  title             String
  description       String?
  status            TaskStatus   @default(TODO)
  priority          TaskPriority @default(MEDIUM)
  dueDate           DateTime?
  assignedToId      String
  relatedDealId     String?
  relatedFollowUpId String?
  createdById       String
  createdAt         DateTime     @default(now())
  completedAt       DateTime?
  tags              String[]
  assignedTo        User         @relation("assignedTo", fields: [assignedToId], references: [id])
  createdBy         User         @relation(fields: [createdById], references: [id])
  relatedDeal       Deal?        @relation(fields: [relatedDealId], references: [id])
  relatedFollowUp   FollowUp?    @relation(fields: [relatedFollowUpId], references: [id])

  @@index([status])
  @@index([assignedToId])
  @@index([dueDate])
}

model Quotation {
  id              String          @id @default(cuid())
  dealId          String
  quotationNumber String          @unique
  customerId      String
  status          QuotationStatus @default(DRAFT)
  issueDate       DateTime
  expiryDate      DateTime?
  items           Json
  subtotal        Decimal
  taxAmount       Decimal
  discountAmount  Decimal
  totalAmount     Decimal
  notes           String?
  pdfUrl          String?
  sentAt          DateTime?
  approvedById    String?
  approvedAt      DateTime?
  createdById     String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  revision        Int             @default(1)
  activityLogs    ActivityLog[]
  orders          Order[]
  createdBy       User            @relation(fields: [createdById], references: [id])
  customer        Customer        @relation(fields: [customerId], references: [id])
  deal            Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([customerId])
  @@index([dealId])
}

model Order {
  id            String        @id @default(cuid())
  quotationId   String?
  customerId    String
  dealId        String?
  orderNumber   String        @unique
  poNumber      String?
  poDate        DateTime?
  status        OrderStatus   @default(PENDING)
  deliveryDate  DateTime?
  invoiceUrl    String?
  paymentStatus PaymentStatus @default(PENDING)
  totalAmount   Decimal
  amountPaid    Decimal       @default(0)
  createdAt     DateTime      @default(now())
  deliveredAt   DateTime?
  updatedAt     DateTime      @updatedAt
  customer      Customer      @relation(fields: [customerId], references: [id])
  deal          Deal?         @relation(fields: [dealId], references: [id])
  quotation     Quotation?    @relation(fields: [quotationId], references: [id])

  @@index([status])
  @@index([customerId])
  @@index([paymentStatus])
}

model Product {
  id             String          @id @default(cuid())
  sku            String          @unique
  name           String
  category       String?
  description    String?
  basePrice      Decimal
  tax            Decimal
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  inventory      Inventory?
  vendorProducts VendorProduct[]

  @@index([sku])
}

model Inventory {
  id                  String    @id @default(cuid())
  productId           String    @unique
  quantity            Int       @default(0)
  reorderLevel        Int?
  warehouseLocation   String?
  lastRestockDate     DateTime?
  lastRestockQuantity Int?
  updatedAt           DateTime  @updatedAt
  product             Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Vendor {
  id           String          @id @default(cuid())
  vendorName   String
  gstNumber    String          @unique
  email        String?
  phone        String?
  website      String?
  paymentTerms String?
  rating       Int?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  products     VendorProduct[]

  @@index([vendorName])
}

model VendorProduct {
  id           String  @id @default(cuid())
  vendorId     String
  productId    String
  vendorSku    String
  vendorPrice  Decimal
  leadTime     Int?
  minimumOrder Int?
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor       Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, productId])
  @@index([vendorId])
}

model Ticket {
  id                         String         @id @default(cuid())
  ticketNumber               String         @unique
  customerId                 String
  dealId                     String?
  type                       TicketType
  priority                   TicketPriority
  status                     TicketStatus   @default(OPEN)
  subject                    String
  description                String
  assignedToId               String
  createdAt                  DateTime       @default(now())
  resolvedAt                 DateTime?
  closedAt                   DateTime?
  slaBreached                Boolean        @default(false)
  resolutionNotes            String?
  customerSatisfactionRating Int?
  createdById                String
  assignedTo                 User           @relation("assignedTo", fields: [assignedToId], references: [id])
  createdBy                  User           @relation("createdBy", fields: [createdById], references: [id])
  customer                   Customer       @relation(fields: [customerId], references: [id])
  deal                       Deal?          @relation(fields: [dealId], references: [id])

  @@index([status])
  @@index([assignedToId])
  @@index([customerId])
}

model ActivityLog {
  id          String         @id @default(cuid())
  userId      String
  action      ActivityAction
  entityType  String
  entityId    String
  changes     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime       @default(now())
  leadId      String?
  customerId  String?
  dealId      String?
  quotationId String?
  customer    Customer?      @relation(fields: [customerId], references: [id])
  deal        Deal?          @relation(fields: [dealId], references: [id])
  lead        Lead?          @relation(fields: [leadId], references: [id])
  quotation   Quotation?     @relation(fields: [quotationId], references: [id])
  user        User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}

model Notification {
  id                String           @id @default(cuid())
  userId            String
  type              NotificationType
  title             String
  message           String
  relatedEntityType String?
  relatedEntityId   String?
  isRead            Boolean          @default(false)
  readAt            DateTime?
  createdAt         DateTime         @default(now())
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model ApprovalRequest {
  id              String         @id @default(cuid())
  type            ApprovalType
  entityType      String
  entityId        String
  requestedBy     String
  approvedBy      String?
  status          ApprovalStatus @default(PENDING)
  reason          String?
  rejectionReason String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  approvedByUser  User?          @relation("ApprovalApprovedBy", fields: [approvedBy], references: [id])
  lead            Lead           @relation(fields: [entityId], references: [id], onDelete: Cascade)
  requestedByUser User           @relation("ApprovalRequestedBy", fields: [requestedBy], references: [id])

  @@index([status])
  @@index([entityType])
  @@index([requestedBy])
  @@index([approvedBy])
}

model DailyActivity {
  id         String    @id @default(cuid())
  userId     String
  date       String
  activities String
  loginTime  DateTime?
  logoutTime DateTime?
  totalHours Decimal?
  notes      String?
  isEditable Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model TimeLog {
  id              String    @id @default(cuid())
  userId          String
  loginTime       DateTime
  logoutTime      DateTime?
  sessionDuration Int?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loginTime])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  createdById String
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  priority    String    @default("NORMAL")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([isPublished])
  @@index([createdById])
  @@index([publishedAt])
}

enum UserRole {
  ADMIN
  SALES_MANAGER
  SALES_EXEC
  SUPPORT
  VIEWER
  SUPER_ADMIN
}

enum LeadSource {
  WEBSITE
  REFERRAL
  WALKIN
  CALL
  EMAIL
  ADVERTISEMENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  REJECTED
  CONVERTED
  WON
  LOST
  SUSPECT
  PROSPECT
  NEGOTIATION
  COMMIT
  DROPPED
  ON_HOLD
}

enum CustomerCategory {
  PROSPECT
  ACTIVE
  INACTIVE
  LOST
}

enum DealStage {
  SUSPECT
  PROSPECT
  APPROACH
  NEGOTIATION
  CLOSURE
  ONGOING
}

enum FollowUpType {
  CALL
  EMAIL
  MEETING
  WHATSAPP
  SITE_VISIT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  FULFILLED
  INVOICED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  COMPLETED
}

enum TicketType {
  TECHNICAL
  BILLING
  GENERAL
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ActivityAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  EXPORT
  SEND_EMAIL
}

enum NotificationType {
  FOLLOW_UP_REMINDER
  TASK_DUE
  DEAL_UPDATED
  LEAD_ASSIGNED
  QUOTATION_APPROVED
  ORDER_CONFIRMED
  PAYMENT_RECEIVED
  TICKET_ASSIGNED
}

enum ApprovalType {
  LEAD_DELETE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
